// Auth.js: https://authjs.dev/getting-started/adapters/prisma
// Prisma 7: client output to src/generated/prisma

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  PROFESSOR
  CIDA
}

// -------- Auth.js models (extended) ----------------------------------------
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  /// Argon2/bcrypt hash; set only for password login
  passwordHash  String?   @map("password_hash")
  role          UserRole  @default(PROFESSOR)

  accounts       Account[]
  sessions       Session[]
  authenticators Authenticator[]

  sectionInstructors SectionInstructor[]

  @@map("users")
}

model Account {
  id                 String  @id @default(cuid())
  userId             String  @map("user_id")
  type               String
  provider           String
  providerAccountId  String  @map("provider_account_id")
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId], map: "account_provider_key")
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Authenticator {
  credentialID         String  @id
  userId               String
  providerAccountId    String
  credentialPublicKey  String
  counter              Int
  credentialDeviceType String
  credentialBackedUp   Boolean
  transports           String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// -------- Academic structure ------------------------------------------------

model AcademicYear {
  id        String   @id @default(cuid())
  /// e.g. "2024–2025"
  label     String
  startYear Int
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  terms     Term[]

  @@index([startYear])
}

/// Fall / Spring / Summer or admin-defined (custom label, unique key)
model TermSeason {
  id        String   @id @default(cuid())
  key       String   @unique
  label     String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  terms     Term[]

  @@index([sortOrder])
}

model Term {
  id             String       @id @default(cuid())
  academicYearId String
  termSeasonId   String
  sortOrder      Int          @default(0)
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  termSeason     TermSeason   @relation(fields: [termSeasonId], references: [id], onDelete: Restrict)
  offerings      CourseOffering[]

  @@unique([academicYearId, termSeasonId])
  @@index([academicYearId])
}

// -------- Course catalog & offerings (per term) + sections ----------------

model Course {
  id        String   @id @default(cuid())
  name      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  offerings CourseOffering[]
}

model CourseOffering {
  id        String   @id @default(cuid())
  courseId  String
  termId    String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  term     Term   @relation(fields: [termId], references: [id], onDelete: Cascade)
  sections Section[]

  @@unique([courseId, termId])
  @@index([termId])
}

model Section {
  id               String   @id @default(cuid())
  courseOfferingId String
  /// e.g. "001", "A"
  label            String
  sortOrder        Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  courseOffering CourseOffering      @relation(fields: [courseOfferingId], references: [id], onDelete: Cascade)
  courseItems    CourseItem[]
  instructors    SectionInstructor[]

  @@index([courseOfferingId])
}

model SectionInstructor {
  userId    String
  sectionId String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  section   Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@id([userId, sectionId])
  @@index([userId])
  @@index([sectionId])
}

// -------- Item types & per-section items (assignments, etc.) ----------------

model ItemTypeDefinition {
  id        String   @id @default(cuid())
  key       String   @unique
  label     String
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  courseItems CourseItem[]
}

/// Admin-managed catalog. Faculty assign one or more to each assignment/quiz/exam/project.
model CodeNumber {
  id        String   @id @default(cuid())
  /// e.g. "6A" — unique, stored uppercase
  value     String   @unique
  label     String?
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  itemLinks CourseItemCode[]
}

model CourseItem {
  id         String   @id @default(cuid())
  sectionId  String
  itemTypeId String
  number     Int
  /// Optional custom title; if null, UI can show type + number
  title      String?
  sortOrder  Int      @default(0)
  /// Pasted OneDrive (or any) share URL
  oneDriveUrl String?  @map("one_drive_url")
  linkTitle  String?  @map("link_title")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  section  Section            @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  itemType ItemTypeDefinition  @relation(fields: [itemTypeId], references: [id], onDelete: Restrict)
  codes    CourseItemCode[]

  @@unique([sectionId, itemTypeId, number])
  @@index([sectionId])
}

model CourseItemCode {
  id            String   @id @default(cuid())
  courseItemId  String
  codeNumberId  String
  courseItem    CourseItem @relation(fields: [courseItemId], references: [id], onDelete: Cascade)
  codeNumber    CodeNumber @relation(fields: [codeNumberId], references: [id], onDelete: Restrict)

  @@unique([courseItemId, codeNumberId])
  @@index([codeNumberId])
}
