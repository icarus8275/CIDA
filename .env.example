# Database (Neon or local Docker)
DATABASE_URL="postgresql://user:pass@host:5432/db?sslmode=require"

# Auth.js — required: openssl rand -base64 32
AUTH_SECRET=""

# Must match the site URL (no trailing slash)
AUTH_URL="http://localhost:3000"

# Comma-separated emails that become ADMIN on first sign-in (optional)
# BOOTSTRAP_ADMIN_EMAILS=""

# Optional: Auth.js console debug
# AUTH_DEBUG="true"

# Optional: encrypt OAuthTokenStore payloads (legacy; no longer used if Graph removed)
# OAUTH_ENCRYPTION_KEY=""

# i18n: set to "false" to hide EN/한 switcher in production
# NEXT_PUBLIC_SHOW_LOCALE_SWITCHER="true"
#
# English-only: ignore locale cookie, hide switcher, all UI in English (one deploy flag)
# NEXT_PUBLIC_I18N_ENGLISH_ONLY="true"
# (alias) NEXT_PUBLIC_ENGLISH_ONLY="true"

# Seed / first admin (used by `npm run db:seed`)
# SEED_ADMIN_EMAIL="admin@example.edu"
# SEED_ADMIN_PASSWORD=""

# Dev-only: same as seed if you use `prisma/seed.ts` with AUTH_DEV_*
# AUTH_DEV_EMAIL=""
# AUTH_DEV_PASSWORD=""
