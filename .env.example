# Database (Neon or local Docker)
DATABASE_URL="postgresql://user:pass@host:5432/db?sslmode=require"

# Auth.js — required: openssl rand -base64 32
AUTH_SECRET=""

# Microsoft Entra ID (app registration) — single-tenant school/work directory
AUTH_MICROSOFT_ENTRA_ID_ID=""
AUTH_MICROSOFT_ENTRA_ID_SECRET=""
# Must be: https://login.microsoftonline.com/<YOUR_TENANT_ID>/v2.0/
AUTH_MICROSOFT_ENTRA_ID_ISSUER="https://login.microsoftonline.com/TENANT_ID/v2.0/"

# Must match the site URL (no trailing slash)
# Local: http://localhost:3000
# Vercel: https://your-app.vercel.app
AUTH_URL="http://localhost:3000"

# Entra: Authentication → add redirect URI (type: Web) for the URL below:
#   {AUTH_URL}/api/auth/callback/microsoft-entra-id
# API permissions (delegated): openid, profile, email, offline_access, Files.Read, Files.ReadWrite

# Comma-separated emails that become ADMIN on first sign-in
# BOOTSTRAP_ADMIN_EMAILS=""

# Optional: Auth.js console debug
# AUTH_DEBUG="true"

# Optional: local-only email/password (never enable in production)
# Set all three, plus run: npm run dev
# ALLOW_DEV_PASSWORD_LOGIN="true"
# AUTH_DEV_EMAIL="dev@local.test"
# AUTH_DEV_PASSWORD=""

# Optional: encrypt OAuthTokenStore payloads
# OAUTH_ENCRYPTION_KEY=""

# i18n: EN / 한국어 switcher in the corner (set to "false" in production to hide the menu)
# NEXT_PUBLIC_SHOW_LOCALE_SWITCHER="true"
